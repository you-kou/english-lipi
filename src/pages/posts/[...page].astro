---
import type { GetStaticPaths } from "astro";
import { getAllPosts } from "@/utils/content";
import PageLayout from "@/layouts/PageLayout.astro";
import PostFeed from "@/components/content/PostFeed.astro";
import siteConfig from "@/site.config";

export const getStaticPaths = (async ({
  paginate,
}) => {
  const allPosts = await getAllPosts();

  return paginate(allPosts, {
    pageSize: siteConfig.postsPerPage,
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;
const title = isFirstPage
  ? "Posts"
  : `Posts - Page ${page.currentPage}`;
const description =
  "Browse all published posts.";
---
<PageLayout
  title={title}
  description={description}
>
  <PostFeed
    posts={page.data}
    variant="archive"
  />

  <nav class="mt-12 flex items-center justify-between">
    <div>
      {
        page.url.prev && (
          <a
            href={page.url.prev}
            class="text-muted-foreground hover:text-foreground inline-flex min-h-10 items-center transition-colors"
          >
            ← Previous
          </a>
        )
      }
    </div>

    <div class="text-muted-foreground text-sm">
      Page {page.currentPage} of {page.lastPage}
    </div>

    <div>
      {
        page.url.next && (
          <a
            href={page.url.next}
            class="text-muted-foreground hover:text-foreground inline-flex min-h-10 items-center transition-colors"
          >
            Next →
          </a>
        )
      }
    </div>
  </nav>
</PageLayout>
