---
import siteConfig from '@/site.config';
import BaseLayout from "@/layouts/BaseLayout.astro";
import SEO from "@/components/SEO.astro";
import { getAllPosts } from "@/utils/content";
import PostFeed from "@/components/content/PostFeed.astro";
import HomeHero from "@/components/content/HomeHero.astro";
import { generateWebsiteSchema } from "@/utils/schema";

const allPosts = await getAllPosts();
const structuredData = generateWebsiteSchema();
---
<BaseLayout schema={structuredData}>
	<SEO slot="seo" title="Home" description={siteConfig.description} ogImage="/og/default.png" />
	<h1 class="sr-only">{siteConfig.title}</h1>
	
	<HomeHero />
	<div class="divider" />
	<section class="space-y-8">
		<PostFeed
			posts={allPosts.slice(0, 1)}
			variant="featured"
		/>

		<PostFeed
			posts={allPosts.slice(1, siteConfig.recentPosts)}
			variant="timeline"
			sectionTitle="Recent"
		/>

		<a
			href="/archive"
			class="text-sm font-ui text-muted-foreground hover:text-accent transition-colors duration-200 no-underline inline-flex items-center gap-1.5"
		>
			all posts <span aria-hidden="true">→</span>
		</a>
	</section>

</BaseLayout>
