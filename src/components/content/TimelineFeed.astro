---
import type { Post } from "@/utils/content";
import PostFeedTitle from "./PostFeedTitle.astro";
import PostFeedMeta from "./PostFeedMeta.astro";

type Props = {
  posts: Post[];
};

const { posts } = Astro.props;
---

<div class="timeline">
  {posts.map((post) => (
    <article class="py-4 first:pt-0">
      <PostFeedTitle
        post={post}
        class="font-display text-lg leading-snug font-medium"
      />

      <div class="mt-1">
        <PostFeedMeta
          post={post}
          showReadingTime
        />
      </div>
    </article>
  ))}
</div>