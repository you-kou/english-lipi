---
import { type Post, getPostUrl } from "@/utils/content";
import ArrowLeft from "@/assets/arrow-left.svg";
import ArrowRight from "@/assets/arrow-right.svg";

interface Props {
  prevPost?: Post;
  nextPost?: Post;
}

const { prevPost, nextPost } = Astro.props;
---
<section class="flex flex-col">
  <nav class="post-navigation py-4" aria-label="Post navigation">
    {/* GLOBAL PREV / NEXT */}
    {(prevPost || nextPost) && (
      <div class:list={[
	          "post-nav flex flex-col gap-4 text-sm md:flex-row",
          {
            "md:justify-between": !(prevPost && nextPost),
          }
        ]}>
          {prevPost && (
            <a
              href={getPostUrl(
                  prevPost.id,
                  prevPost.filePath
                )}
	              class="group flex flex-1 flex-col gap-1 rounded-xl border border-border p-4 no-underline transition-colors hover:border-accent/50"
            >
	              <div class="flex items-center justify-start gap-2 text-xs font-ui font-medium uppercase tracking-wide text-muted-foreground">
                <ArrowLeft class="size-4 transition-transform duration-200 group-hover:-translate-x-0.5" />
                <span class="text-minimal">Previous</span>
              </div>
	              <span class="text-xl leading-snug text-foreground">
                {prevPost.data.title}
              </span>
            </a>
          )}

          {nextPost && (
            <a
              href={getPostUrl(
                  nextPost.id,
                  nextPost.filePath
                )}
	              class="group flex flex-1 flex-col gap-1 rounded-xl border border-border p-4 text-right no-underline transition-colors hover:border-accent/50"
            >
	              <div class="flex items-center justify-end gap-2 text-xs font-ui font-medium uppercase tracking-wide text-muted-foreground">
                <span class="text-minimal">Next</span>
                <ArrowRight class="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
              </div>
	              <span class="text-xl leading-snug text-foreground">
                {nextPost.data.title}
              </span>
            </a>
          )}
      </div>
    )}
  </nav>
  <div class="divider" />
</section>
