---
import { getEntry, render } from "astro:content";
import siteConfig from "@/site.config";
const homeEntry = await getEntry("pages", "home-intro");
const Content = homeEntry ? (await render(homeEntry)).Content : null;

---

<section class="home-intro flex flex-col gap-4" data-pagefind-ignore>
  <div class="app-prose home-intro-content">
    {Content ? <Content /> : null}
  </div>
  <div class="home-intro-footer mt-4">
    <nav
      class="flex flex-wrap font-mono items-center gap-x-4 text-sm"
      aria-label="Social links"
    >
      {siteConfig.social.map((item) => (
        <a
          href={item.url}
          class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200 no-underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          {item.title}
        </a>
      ))}
    </nav>
    <div class="divider" />
  </div>
</section>