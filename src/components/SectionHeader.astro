---
interface Props {
  title?: string;
  subheading?: string;
}

const { title, subheading } = Astro.props;
---

<div class="mb-2 sm:mb-4 flex flex-col gap-2 py-2">
  {title && (
    <span class="m-0 font-ui text-xs uppercase tracking-widest text-muted-foreground">
      {title}
    </span>
  )}
  {subheading && (
    <p class="max-w-xl text-sm leading-relaxed text-muted-foreground">
      {subheading}
    </p>
  )}
</div>
