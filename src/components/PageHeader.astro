---
import { slugify } from '@/utils/text';

interface Props {
  title?: string;
  subheading?: string;
  transitionName?: string;
}
const { title, subheading, transitionName } = Astro.props;
---
<section class="mb-4 flex flex-col gap-3">
  {title && (
    <h1 
      class="mt-0 mb-1 font-content text-4xl leading-tight font-semibold tracking-tight text-foreground md:text-5xl"
      transition:name={transitionName}
    > 
      {title} 
    </h1>
  )}
  {subheading && (
    <p class="max-w-2xl font-ui text-base leading-relaxed text-muted-foreground">
      {subheading}
    </p>
  )}
  <slot name="meta" />
  <slot />
</section>
